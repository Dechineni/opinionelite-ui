generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            String         @id @default(cuid())
  code          String         @unique @default(dbgenerated("('C'::text || (nextval('client_code_seq'::regclass))::text)"))
  name          String
  contactPerson String
  email         String?
  contactNumber String?
  countryCode   String
  website       String?

// NEW: API-provider support
  apiUrl        String?
  apiKey        String?
  secretKey     String?

  // NEW: provider-specific support
  providerType  String?
  memberApiUrl  String?
  partnerGuid   String?
  panelGuidEnUs String?
  panelGuidEnGb String?

  refDataUrl     String?
  partnerAuthKey String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects      Project[]
  projectGroups ProjectGroup[]

  apiSurveySelections ApiSurveySelection[]
}

model Supplier {
  id                    String                  @id @default(cuid())
  code                  String                  @unique @default(dbgenerated("('S'::text || lpad((nextval('supplier_code_seq'::regclass))::text, 4, '0'::text))"))
  name                  String
  website               String?
  countryCode           String
  email                 String?
  contactNumber         String?
  panelSize             Int?
  completeUrl           String
  terminateUrl          String
  overQuotaUrl          String
  qualityTermUrl        String
  surveyCloseUrl        String
  about                 String?
  allowedCountries      String[]
  api                   Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  projectMappings       ProjectSupplierMap[]
  SupplierRedirectEvent SupplierRedirectEvent[]
  reconciliations       Reconciliation[]
}

model ProjectGroup {
  id            String    @id @default(cuid())
  clientId      String
  name          String
  description   String?
  dynamicThanks Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
  client        Client    @relation(fields: [clientId], references: [id])
}

model Project {
  id                    String                  @id @default(cuid())
  code                  String                  @unique @default(dbgenerated("('SR'::text || lpad((nextval('project_code_seq'::regclass))::text, 4, '0'::text))"))
  clientId              String
  groupId               String?
  name                  String
  managerEmail          String
  category              String
  status                ProjectStatus           @default(ACTIVE)
  description           String?
  countryCode           String
  languageCode          String
  currency              String                  @default("USD")
  loi                   Int
  ir                    Float
  sampleSize            Int
  clickQuota            Int
  projectCpi            Decimal                 @db.Decimal(10, 2)
  supplierCpi           Decimal?                @db.Decimal(10, 2)
  startDate             DateTime
  endDate               DateTime
  preScreen             Boolean                 @default(false)
  exclude               Boolean                 @default(false)
  geoLocation           Boolean                 @default(false)
  dynamicThanksUrl      Boolean                 @default(false)
  uniqueIp              Boolean                 @default(false)
  uniqueIpDepth         Int?
  tSign                 Boolean                 @default(false)
  speeder               Boolean                 @default(false)
  speederDepth          Int?
  mobile                Boolean                 @default(true)
  tablet                Boolean                 @default(false)
  desktop               Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  surveyLinkType        SurveyLinkType?         @default(SINGLE)
  surveyLiveUrl         String?
  surveyTestUrl         String?
  surveyName            String?
  prescreenAnswers      PrescreenAnswer[]
  prescreenQuestions    PrescreenQuestion[]     @relation("ProjectPrescreenQuestions")
  client                Client                  @relation(fields: [clientId], references: [id])
  group                 ProjectGroup?           @relation(fields: [groupId], references: [id])
  supplierMappings      ProjectSupplierMap[]
  respondents           Respondent[]
  SupplierRedirectEvent SupplierRedirectEvent[]
  SurveyRedirect        SurveyRedirect[]
  reconciliations       Reconciliation[]

  apiSurveySelection ApiSurveySelection?
  respondentLaunchProfiles RespondentLaunchProfile[]

  sentryEnabled        Boolean  @default(false)
  sentryProjectId      String?
  sentryTemplateId     String?
  sentryLiveUrl        String?
  sentryTestUrl        String?
  sentryReportingUrl   String?
  sentryProjectStatus  String?
  sentryHashingEnabled Boolean @default(false)
  sentryVerisoulEnabled        Boolean @default(false)
  sentryVerisoulTermFake       Boolean @default(false)
  sentryVerisoulTermSuspicious Boolean @default(false)
}

/// A supplier mapped to a project (1 row per supplier per project)
model ProjectSupplierMap {
  id                String                  @id @default(cuid())
  /// FKs
  projectId         String
  supplierId        String
  /// Quotas & pricing
  quota             Int
  clickQuota        Int
  cpi               Decimal                 @db.Decimal(10, 2)
  /// Redirection mode
  redirectionType   SupplierRedirectionType
  /// STATIC_REDIRECT: (no URL stored here — supplier hits your live survey URL)
  /// STATIC_POSTBACK: (no URL stored here — you’ll post back to supplier)
  /// DYNAMIC_POSTBACK:
  postBackUrl       String?
  /// DYNAMIC_REDIRECT (the 5 result URLs)
  completeUrl       String?
  terminateUrl      String?
  overQuotaUrl      String?
  qualityTermUrl    String?
  surveyCloseUrl    String?
  /// Misc / UI helpers
  supplierProjectId String?
  allowTraffic      Boolean                 @default(false)
  testLinkEnabled   Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  supplierUrl       String?
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier          Supplier                @relation(fields: [supplierId], references: [id])

  @@unique([projectId, supplierId])
  @@index([projectId])
  @@index([supplierId])
}

model PrescreenQuestion {
  id            String               @id @default(cuid())
  projectId     String
  title         String
  question      String
  controlType   PrescreenControlType
  textMinLength Int?                 @default(0)
  textMaxLength Int?
  textType      PrescreenTextType?
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  answers       PrescreenAnswer[]
  options       PrescreenOption[]
  project       Project              @relation("ProjectPrescreenQuestions", fields: [projectId], references: [id], onDelete: Cascade)
}

model PrescreenOption {
  id         String            @id @default(cuid())
  questionId String
  label      String
  value      String
  sortOrder  Int               @default(0)
  enabled    Boolean           @default(false)
  validate   Boolean           @default(false)
  quota      Int               @default(0)
  question   PrescreenQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Respondent {
  id                    String                  @id @default(cuid())
  projectId             String
  externalId            String
  supplierId            String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  answers               PrescreenAnswer[]
  project               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SupplierRedirectEvent SupplierRedirectEvent[]
  SurveyRedirect        SurveyRedirect[]

  @@unique([projectId, externalId, supplierId], map: "respondent_project_ext_supplier_unique")
  @@index([projectId])
}

model PrescreenAnswer {
  id             String            @id @default(cuid())
  projectId      String
  respondentId   String
  questionId     String
  /// Store answers in flexible fields
  /// For TEXT:    answerText
  /// For RADIO/DROPDOWN: answerValue (single)
  /// For CHECKBOX: selectedValues (array)
  answerText     String?
  answerValue    String?
  selectedValues String[]
  answeredAt     DateTime          @default(now())
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  question       PrescreenQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  respondent     Respondent        @relation(fields: [respondentId], references: [id], onDelete: Cascade)

  @@unique([respondentId, questionId])
  @@index([projectId])
}

model SurveyRedirect {
  /// 20-char unique id you pass to the client as pid
  id           String          @id
  projectId    String
  /// Link it back to the respondent if we were able to resolve/create one
  respondentId String?
  /// For convenience/auditing
  supplierId   String?
  externalId   String?
  destination  String
  createdAt    DateTime        @default(now())
  result       RedirectResult?
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  respondent   Respondent?     @relation(fields: [respondentId], references: [id])

  @@unique([projectId, supplierId, externalId], name: "SurveyRedirect_nat_unique", map: "SurveyRedirect_nat_unique")
  @@index([projectId])
  @@index([respondentId])
}

model SupplierRedirectEvent {
  id           String          @id @default(cuid())
  projectId    String
  supplierId   String?
  respondentId String?
  pid          String?
  outcome      RedirectOutcome
  createdAt    DateTime        @default(now())
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  respondent   Respondent?     @relation(fields: [respondentId], references: [id])
  supplier     Supplier?       @relation(fields: [supplierId], references: [id])

  @@index([projectId, supplierId, outcome])
  @@index([pid])
}

model Reconciliation {
  id String @id @default(cuid())

  // Search Identifier (survey attempt pid)
  pid String @unique

  // References (cuid ids)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  projectCode        String
  projectName        String
  supplierName       String
  supplierIdentifier String

  // Latest known outcome for this pid
  outcome     RedirectOutcome?
  lastEventAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([supplierId])
  @@index([supplierIdentifier])
  @@index([outcome])
}

model ApiSurveySelection {
  id           String   @id @default(cuid())

  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)

  providerType  String
  countryCode   String

  surveyCode    String
  quotaId       String
  surveyName    String

  quota         String?
  loi           String?
  ir            String?
  cpi           String?

  liveUrl       String?
  testUrl       String?

  targetingJson String?
  rawSurveyJson String?

  projectId     String?  @unique
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([clientId, countryCode, surveyCode, quotaId], map: "ApiSurveySelection_unique_selection")
  @@index([clientId])
  @@index([providerType])
  @@index([countryCode])
  @@index([surveyCode])
  @@index([quotaId])
}

model RespondentLaunchProfile {
  id          String   @id @default(cuid())
  projectId   String
  supplierId  String?
  externalId  String
  birthDate   DateTime
  gender      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, supplierId, externalId])
  @@index([projectId])
  @@index([supplierId])
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  CLOSED
  INVOICED
  BID
}

enum SurveyLinkType {
  SINGLE
  MULTI
}

/// Four redirection modes shown in the UI
enum SupplierRedirectionType {
  STATIC_REDIRECT
  STATIC_POSTBACK
  DYNAMIC_REDIRECT
  DYNAMIC_POSTBACK
}

enum PrescreenControlType {
  TEXT
  RADIO
  DROPDOWN
  CHECKBOX
}

enum PrescreenTextType {
  EMAIL
  CONTACTNO
  ZIPCODE
  CUSTOM
}

enum RedirectResult {
  COMPLETE
  TERMINATE
  OVERQUOTA
  QUALITYTERM
  CLOSE
}

enum RedirectOutcome {
  COMPLETE
  TERMINATE
  OVER_QUOTA
  DROP_OUT
  QUALITY_TERM
  SURVEY_CLOSE
}
